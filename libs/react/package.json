    "@types/react": "^19.2.17",
    "react": "^19.2.7"
  },
  "peerDependencies": {
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/router-core": "^1.171.14",
    "react": "^19.2.7"
  }
